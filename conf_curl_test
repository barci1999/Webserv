server {
    listen 8080;

    root Parseo_solo_toca_Pablo/www;
	index index.html;

    client_max_body_size 1000000;

    error_page 400 /error_pages/400.html;
    error_page 403 /error_pages/403.html;
    error_page 404 /error_pages/404.html;
    error_page 405 /error_pages/405.html;
    error_page 413 /error_pages/413.html;
    error_page 415 /error_pages/415.html;
    error_page 500 /error_pages/500.html;
    error_page 501 /error_pages/501.html;

    # 🔵 HOME
    location /pepe {
		root Parseo_solo_toca_Pablo/www;
        allowed_methods GET;
        autoindex on;
    }

    # 🟣 TEST
    location /test {
		root Parseo_solo_toca_Pablo/www/test;
        allowed_methods GET;
        index parrot.html;
    }

    # 🟡 PÁGINA POST
    location /post_page {
        root Parseo_solo_toca_Pablo/www/pages;
        index post.html;
        allowed_methods GET;
    }

    # 🔴 PÁGINA DELETE
    location /delete_page {
        root Parseo_solo_toca_Pablo/www/pages;
        index delete.html;
        allowed_methods GET;
    }

    # 🟣 ENDPOINT POST
    location /upload {
        root Parseo_solo_toca_Pablo/www/upload;
        allowed_methods POST;
        upload_enable on;
    }
	location /upload_page {
        root Parseo_solo_toca_Pablo/www/pages;
        index post.html;
        allowed_methods GET;
    }

    # 🔴 ENDPOINT DELETE
    location /delete {
        root Parseo_solo_toca_Pablo/www/upload;
        allowed_methods DELETE;
    }
}